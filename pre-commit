#!/usr/bin/env python
"""
pre-commit hook — bloqueia o commit se a versão no app.json
não foi incrementada em relação ao último commit.
"""
import subprocess
import sys
import json


def get_versao_do_json(conteudo):
    try:
        return json.loads(conteudo).get("version")
    except Exception:
        return None


def get_versao_commitada():
    try:
        conteudo = subprocess.check_output(
            ["git", "show", "HEAD:app.json"],
            stderr=subprocess.DEVNULL
        ).decode("utf-8")
        return get_versao_do_json(conteudo)
    except subprocess.CalledProcessError:
        return None


def get_versao_staged():
    try:
        conteudo = subprocess.check_output(
            ["git", "show", ":app.json"],
            stderr=subprocess.DEVNULL
        ).decode("utf-8")
        return get_versao_do_json(conteudo)
    except subprocess.CalledProcessError:
        return None


def main():
    versao_commitada = get_versao_commitada()
    versao_staged    = get_versao_staged()

    if versao_staged is None:
        sys.exit(0)

    if versao_commitada is None:
        print(f"[hook] Primeiro commit detectado. Versão: {versao_staged}")
        sys.exit(0)

    if versao_staged == versao_commitada:
        print()
        print("=" * 55)
        print("  COMMIT BLOQUEADO")
        print("=" * 55)
        print(f"  Versão atual:    {versao_commitada}")
        print(f"  Versão no stage: {versao_staged}")
        print()
        print("  Atualize a versão no app.json antes de")
        print("  fazer o commit.")
        print()
        print("  Exemplo: 1.0.0  →  1.0.1")
        print("=" * 55)
        print()
        sys.exit(1)

    print(f"[hook] Versão atualizada: {versao_commitada} → {versao_staged} ✓")
    sys.exit(0)


if __name__ == "__main__":
    main()
